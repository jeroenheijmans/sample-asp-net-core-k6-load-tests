@model SampleOrg.Foo.Website.Models.ColorEntry[]
@{
    ViewData["Title"] = "Colors";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item active" aria-current="page">Colors</li>
    </ol>
</nav>

<h1 class="mb-4">ISCC-NBS Colors</h1>
<table class="table table-hover align-middle">
    <thead class="table-light">
        <tr>
            <th>Swatch</th>
            <th>Name</th>
            <th>Category</th>
            <th>Hex</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var color in Model)
        {
            <tr>
                <td>
                    <a href="/colors/@color.Slug">
                        <div style="width:40px;height:24px;background-color:@color.Hex;border:1px solid #ccc;border-radius:3px;"></div>
                    </a>
                </td>
                <td><a href="/colors/@color.Slug">@color.Name</a></td>
                <td>@color.Category</td>
                <td><code>@color.Hex</code></td>
            </tr>
        }
    </tbody>
</table>
