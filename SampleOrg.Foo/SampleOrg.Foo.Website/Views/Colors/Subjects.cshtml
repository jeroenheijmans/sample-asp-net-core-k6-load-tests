@model (SampleOrg.Foo.Website.Models.ColorEntry Color, SampleOrg.Foo.Website.Models.SubjectEntry[] Subjects)
@{
    ViewData["Title"] = $"{Model.Color.Name}: Subjects";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/colors">Colors</a></li>
        <li class="breadcrumb-item"><a href="/colors/@Model.Color.Slug">@Model.Color.Name</a></li>
        <li class="breadcrumb-item active" aria-current="page">Subjects</li>
    </ol>
</nav>

<div class="d-flex align-items-center gap-3 mb-4">
    <div style="width:40px;height:40px;border-radius:6px;background-color:@Model.Color.Hex;border:1px solid rgba(0,0,0,0.12);flex-shrink:0;"></div>
    <h1 class="mb-0">@Model.Color.Name: Subjects</h1>
</div>

@if (Model.Subjects.Length == 0)
{
    <p class="text-muted fst-italic">No subjects are associated with this color.</p>
}
else
{
    <ul class="list-group list-group-flush">
        @foreach (var subject in Model.Subjects)
        {
            <li class="list-group-item px-0">
                <a href="/colors/@Model.Color.Slug/subjects/@subject.Id" class="text-decoration-none fw-medium">@subject.Name</a>
                <span class="text-muted ms-2" style="font-size:.85rem;">@subject.Category</span>
            </li>
        }
    </ul>
}

<a href="/colors/@Model.Color.Slug" class="btn btn-outline-secondary mt-4">&larr; Back to @Model.Color.Name</a>
